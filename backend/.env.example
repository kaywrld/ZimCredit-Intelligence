# Database
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/zimcredit_db

# Security
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=ZimCredit Intelligence
APP_VERSION=1.0.0
DEBUG=True
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Admin defaults (change immediately after first run)
FIRST_ADMIN_EMAIL=admin@zimcredit.co.zw
FIRST_ADMIN_PASSWORD=Admin@123!
